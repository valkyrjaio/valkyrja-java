<?xml version="1.0" encoding="UTF-8"?>
<!--
    SpotBugs exclude filter — permanent exclusions for false positives.

    This file is the equivalent of phpstan-baseline.neon. Add <Match> entries
    here to suppress known false positives. To suppress a newly found bug
    class across the whole project, use:

        <Match>
            <Bug pattern="BUG_PATTERN_NAME" />
        </Match>

    To suppress for a specific class:

        <Match>
            <Class name="io.valkyrja.some.ClassName" />
            <Bug pattern="BUG_PATTERN_NAME" />
        </Match>

    Run `gradle spotbugsMain` locally to see the full bug report.
-->
<FindBugsFilter
        xmlns="https://github.com/spotbugs/filter/3.0.0"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

    <!--
        Intentional framework design: each module defines its own ThrowableContract,
        RuntimeException, InvalidArgumentException, etc. that extend or implement the
        base framework types. The shadowing is deliberate.
    -->
    <Match>
        <Bug pattern="NM_SAME_SIMPLE_NAME_AS_SUPERCLASS" />
    </Match>
    <Match>
        <Bug pattern="NM_SAME_SIMPLE_NAME_AS_INTERFACE" />
    </Match>

    <!--
        Intentional framework design: Directory.basePath is the runtime-configurable
        application root set during bootstrap. It must be mutable and cannot be final.
    -->
    <Match>
        <Class name="io.valkyrja.application.directory.Directory" />
        <Bug pattern="MS_CANNOT_BE_FINAL" />
    </Match>

    <!--
        Intentional framework design: bootstrapTimezone() is protected so subclasses can
        override the timezone bootstrap behaviour. Calling it from the constructor is safe
        because it only reads from the already-assigned `config` field.
    -->
    <Match>
        <Class name="io.valkyrja.application.kernel.Valkyrja" />
        <Bug pattern="MC_OVERRIDABLE_METHOD_CALL_IN_CONSTRUCTOR" />
    </Match>

    <!--
        Service classes that store injected dependencies by design.
        Dispatchers and the application kernel must hold references to the
        services they were constructed with.
    -->
    <Match>
        <Class name="io.valkyrja.application.kernel.Valkyrja" />
        <Bug pattern="EI_EXPOSE_REP" />
    </Match>
    <Match>
        <Class name="io.valkyrja.application.kernel.Valkyrja" />
        <Bug pattern="EI_EXPOSE_REP2" />
    </Match>
    <Match>
        <Class name="io.valkyrja.dispatch.dispatcher.Dispatcher" />
        <Bug pattern="EI_EXPOSE_REP2" />
    </Match>
    <Match>
        <Class name="io.valkyrja.event.dispatcher.Dispatcher" />
        <Bug pattern="EI_EXPOSE_REP2" />
    </Match>

</FindBugsFilter>
