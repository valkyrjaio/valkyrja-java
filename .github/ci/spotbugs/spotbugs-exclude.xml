<?xml version="1.0" encoding="UTF-8"?>
<!--
    SpotBugs exclude filter — permanent exclusions for false positives.

    This file is the equivalent of phpstan-baseline.neon. Add <Match> entries
    here to suppress known false positives. To suppress a newly found bug
    class across the whole project, use:

        <Match>
            <Bug pattern="BUG_PATTERN_NAME" />
        </Match>

    To suppress for a specific class:

        <Match>
            <Class name="io.valkyrja.some.ClassName" />
            <Bug pattern="BUG_PATTERN_NAME" />
        </Match>

    Run `gradle spotbugsMain` locally to see the full bug report.
-->
<FindBugsFilter
        xmlns="https://github.com/spotbugs/filter/3.0.0"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

    <!--
        Intentional framework design: each module defines its own ThrowableContract,
        RuntimeException, InvalidArgumentException, etc. that extend or implement the
        base framework types. The shadowing is deliberate.
    -->
    <Match>
        <Bug pattern="NM_SAME_SIMPLE_NAME_AS_SUPERCLASS" />
    </Match>
    <Match>
        <Bug pattern="NM_SAME_SIMPLE_NAME_AS_INTERFACE" />
    </Match>

    <!--
        Intentional framework design: Directory.basePath is the runtime-configurable
        application root set during bootstrap. It must be mutable and cannot be final.
    -->
    <Match>
        <Class name="io.valkyrja.application.directory.Directory" />
        <Bug pattern="MS_CANNOT_BE_FINAL" />
    </Match>

    <!--
        Intentional framework design: bootstrapTimezone() is protected so subclasses can
        override the timezone bootstrap behaviour. Calling it from the constructor is safe
        because it only reads from the already-assigned `config` field.
    -->
    <Match>
        <Class name="io.valkyrja.application.kernel.Valkyrja" />
        <Bug pattern="MC_OVERRIDABLE_METHOD_CALL_IN_CONSTRUCTOR" />
    </Match>

    <!--
        Framework-wide: mutable fields are returned/stored by design throughout the framework.
        Adding defensive copies everywhere would contradict the framework's performance goals
        and the intentional mutability of builder/middleware patterns.
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP" />
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2" />
    </Match>

    <!--
        Framework-wide: constructors perform validation and throw on invalid input.
        This is an intentional design — it mirrors PHP's constructor validation pattern
        and the risk of finalizer attacks is accepted.
    -->
    <Match>
        <Bug pattern="CT_CONSTRUCTOR_THROW" />
    </Match>

    <!--
        Framework-wide: methods intentionally declare throws RuntimeException to signal
        unchecked error conditions in framework contracts and route dispatchers.
    -->
    <Match>
        <Bug pattern="THROWS_METHOD_THROWS_RUNTIMEEXCEPTION" />
    </Match>

    <!--
        Framework-wide: protected fields on Controller, Router, InputHandler, etc. are
        declared for subclass access in application code — SpotBugs cannot see subclasses
        outside this analysis scope.
    -->
    <Match>
        <Bug pattern="URF_UNREAD_PUBLIC_OR_PROTECTED_FIELD" />
    </Match>

    <!--
        Framework-wide: AttributeRouteCollector and JsonServerRequest use reflection to
        construct route handlers and parse JSON; catching Exception is required because
        reflection APIs declare checked exceptions that vary by implementation.
    -->
    <Match>
        <Bug pattern="REC_CATCH_EXCEPTION" />
    </Match>

    <!--
        Intentional design: overridable methods called in constructors below are safe
        because they only read already-assigned fields, matching a pattern used throughout
        the framework.
    -->
    <Match>
        <Class name="io.valkyrja.cli.middleware.handler.abstract_.Handler" />
        <Bug pattern="MC_OVERRIDABLE_METHOD_CALL_IN_CONSTRUCTOR" />
    </Match>
    <Match>
        <Class name="io.valkyrja.http.middleware.handler.abstract_.Handler" />
        <Bug pattern="MC_OVERRIDABLE_METHOD_CALL_IN_CONSTRUCTOR" />
    </Match>
    <Match>
        <Class name="io.valkyrja.http.message.header.Header" />
        <Bug pattern="MC_OVERRIDABLE_METHOD_CALL_IN_CONSTRUCTOR" />
    </Match>
    <Match>
        <Class name="io.valkyrja.http.message.request.Request" />
        <Bug pattern="MC_OVERRIDABLE_METHOD_CALL_IN_CONSTRUCTOR" />
    </Match>

    <!--
        Intentional design: InputHandler.run() calls System.exit() as the CLI entry point
        — this is the intended termination path for a CLI application.
    -->
    <Match>
        <Class name="io.valkyrja.cli.server.handler.InputHandler" />
        <Bug pattern="DM_EXIT" />
    </Match>

    <!--
        Intentional design: Exiter.exit is public so that application code can override
        the exit behavior by replacing the field.
    -->
    <Match>
        <Class name="io.valkyrja.cli.server.support.Exiter" />
        <Bug pattern="MS_PKGPROTECT" />
    </Match>

    <!--
        Intentional design: ExchangeCgiHttp.run() hides Http.run() to provide a
        CGI-specific entry point with a different signature.
    -->
    <Match>
        <Class name="io.valkyrja.application.entry.ExchangeCgiHttp" />
        <Bug pattern="HSM_HIDING_METHOD" />
    </Match>

    <!--
        NullAway requires a null guard on requestUri here because the factory method
        can return null in some paths. SpotBugs sees the surrounding flow as non-null,
        but the check is needed to satisfy the NullAway static analysis constraint.
    -->
    <Match>
        <Class name="io.valkyrja.http.message.uri.factory.MarshalUriFactory" />
        <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE" />
    </Match>

    <!--
        Benchmark code: ChildContainerBenchmark.has() return value is intentionally
        ignored — it is exercising the call path for timing purposes, not acting on
        the result.
    -->
    <Match>
        <Class name="io.valkyrja.container.manager.benchmark.ChildContainerBenchmark" />
        <Bug pattern="RV_RETURN_VALUE_IGNORED_NO_SIDE_EFFECT" />
    </Match>

    <!--
        Intentional design: JsonServerRequest silently ignores malformed JSON in the
        constructor — invalid JSON leaves parsedJson as the empty default rather than
        crashing the request. CacheResponseMiddleware silently ignores IOException when
        deleting an expired cache file — deletion is best-effort and failure is
        non-critical.
    -->
    <Match>
        <Class name="io.valkyrja.http.message.request.JsonServerRequest" />
        <Bug pattern="DE_MIGHT_IGNORE" />
    </Match>
    <Match>
        <Class name="io.valkyrja.http.server.middleware.CacheResponseMiddleware" />
        <Bug pattern="DE_MIGHT_IGNORE" />
    </Match>

</FindBugsFilter>
